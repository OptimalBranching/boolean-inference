{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OptimalBranching/boolean-inference/benchmarks/scope/benchmark-scope.schema.json",
  "title": "Combinational arithmetic benchmark scope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scope",
    "coverage_axes",
    "controlled_multiplier_factoring",
    "external_multiplier_equivalence",
    "non_multiplier_arithmetic",
    "diagnostic_controls",
    "exclusions",
    "sources",
    "next_stage"
  ],
  "properties": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "status", "claim_boundary", "change_policy", "design_principles"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "version": {"type": "integer", "minimum": 1},
        "status": {"const": "frozen"},
        "claim_boundary": {"$ref": "#/$defs/text"},
        "change_policy": {"$ref": "#/$defs/text"},
        "design_principles": {"$ref": "#/$defs/texts"}
      }
    },
    "coverage_axes": {"$ref": "#/$defs/ids"},
    "controlled_multiplier_factoring": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "semantic_task", "expected_outcome", "target_population", "scale_policy", "pairing", "fixed_axes", "architectures", "generator_strategy"],
      "properties": {
        "required": {"const": true},
        "semantic_task": {"const": "circuit-preimage"},
        "expected_outcome": {"const": "sat"},
        "target_population": {"$ref": "#/$defs/text"},
        "scale_policy": {"$ref": "#/$defs/text"},
        "pairing": {
          "type": "object",
          "additionalProperties": false,
          "required": ["key", "policy"],
          "properties": {
            "key": {"const": "target-integer"},
            "policy": {"$ref": "#/$defs/text"}
          }
        },
        "fixed_axes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["signedness", "product", "final_adder"],
          "properties": {
            "signedness": {"const": "unsigned"},
            "product": {"const": "exact-full-width"},
            "final_adder": {"const": "ripple-carry"}
          }
        },
        "architectures": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/architecture"}
        },
        "generator_strategy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary_sources", "independent_crosscheck"],
          "properties": {
            "primary_sources": {"$ref": "#/$defs/ids"},
            "independent_crosscheck": {"$ref": "#/$defs/id"}
          }
        }
      }
    },
    "external_multiplier_equivalence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "expected_outcome", "semantic_tasks", "suites"],
      "properties": {
        "required": {"const": true},
        "expected_outcome": {"const": "unsat"},
        "semantic_tasks": {"$ref": "#/$defs/ids"},
        "suites": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/suite"}
        }
      }
    },
    "non_multiplier_arithmetic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "source", "semantic_task", "expected_outcome", "target_policy", "circuits"],
      "properties": {
        "required": {"const": true},
        "source": {"$ref": "#/$defs/id"},
        "semantic_task": {"const": "circuit-preimage"},
        "expected_outcome": {"const": "sat"},
        "target_policy": {"$ref": "#/$defs/text"},
        "circuits": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/circuit"}
        }
      }
    },
    "diagnostic_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "activation_condition", "reporting_policy", "families"],
      "properties": {
        "status": {"const": "conditional"},
        "activation_condition": {"$ref": "#/$defs/text"},
        "reporting_policy": {"$ref": "#/$defs/text"},
        "families": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/diagnostic"}
        }
      }
    },
    "exclusions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/exclusion"}
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source"}
    },
    "next_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evaluation_protocol", "deliberately_deferred"],
      "properties": {
        "evaluation_protocol": {"$ref": "#/$defs/text"},
        "deliberately_deferred": {"$ref": "#/$defs/texts"}
      }
    }
  },
  "$defs": {
    "text": {"type": "string", "minLength": 1},
    "id": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "texts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/text"}
    },
    "ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/id"}
    },
    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "partial_product_generation", "partial_product_accumulation", "final_adder", "rationale"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "partial_product_generation": {"$ref": "#/$defs/id"},
        "partial_product_accumulation": {"$ref": "#/$defs/id"},
        "final_adder": {"$ref": "#/$defs/id"},
        "rationale": {"$ref": "#/$defs/text"}
      }
    },
    "suite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "provenance"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "source": {"$ref": "#/$defs/id"},
        "provenance": {"$ref": "#/$defs/text"}
      }
    },
    "circuit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rationale"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "rationale": {"$ref": "#/$defs/text"}
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "local_generator"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "local_generator": {"$ref": "#/$defs/text"}
      }
    },
    "exclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reason", "reconsider_when"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "reason": {"$ref": "#/$defs/text"},
        "reconsider_when": {"$ref": "#/$defs/text"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "url", "role"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "title": {"$ref": "#/$defs/text"},
        "url": {"type": "string", "minLength": 8, "pattern": "^https://"},
        "role": {"$ref": "#/$defs/text"}
      }
    }
  }
}
