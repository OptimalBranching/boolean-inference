{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OptimalBranching/boolean-inference/experiments/cnc-study.schema.json",
  "title": "Cube-and-Conquer study contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "benchmarks",
    "methods",
    "comparisons",
    "provenance",
    "tuning",
    "execution",
    "metrics",
    "outcomes",
    "outputs",
    "exclusions"
  ],
  "properties": {
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "status", "questions", "change_policy"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "version": {"type": "integer", "minimum": 1},
        "status": {"const": "frozen"},
        "questions": {"$ref": "#/$defs/nonEmptyStrings"},
        "change_policy": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "benchmarks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["families", "held_out_policy"],
      "properties": {
        "held_out_policy": {"$ref": "#/$defs/nonEmptyString"},
        "families": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/benchmarkFamily"}
        }
      }
    },
    "methods": {
      "type": "array",
      "minItems": 4,
      "items": {"$ref": "#/$defs/method"}
    },
    "comparisons": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/comparison"}
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tools", "run_capture"],
      "properties": {
        "run_capture": {"$ref": "#/$defs/nonEmptyStrings"},
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/tool"}
        }
      }
    },
    "tuning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["budget", "visible_splits", "available_information", "forbidden_information", "selection_rule"],
      "properties": {
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["trials_per_method", "wall_time_seconds_per_method"],
          "properties": {
            "trials_per_method": {"type": "integer", "minimum": 1},
            "wall_time_seconds_per_method": {"type": "integer", "minimum": 1}
          }
        },
        "visible_splits": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["training", "validation"]}
        },
        "available_information": {"$ref": "#/$defs/nonEmptyStrings"},
        "forbidden_information": {"$ref": "#/$defs/nonEmptyStrings"},
        "selection_rule": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workers", "scheduler", "seeds", "repetitions", "ordering", "limits"],
      "properties": {
        "workers": {"type": "integer", "minimum": 1},
        "scheduler": {
          "type": "object",
          "additionalProperties": false,
          "required": ["policy", "queue_discipline", "preemption"],
          "properties": {
            "policy": {"$ref": "#/$defs/nonEmptyString"},
            "queue_discipline": {"$ref": "#/$defs/nonEmptyString"},
            "preemption": {"type": "boolean"}
          }
        },
        "seeds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "integer", "minimum": 0}
        },
        "repetitions": {"type": "integer", "minimum": 1},
        "ordering": {"$ref": "#/$defs/nonEmptyString"},
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["memory_mb_per_worker", "cubing_timeout_seconds", "conquer_timeout_seconds_per_cube", "end_to_end_timeout_seconds"],
          "properties": {
            "memory_mb_per_worker": {"type": "integer", "minimum": 1},
            "cubing_timeout_seconds": {"type": "integer", "minimum": 1},
            "conquer_timeout_seconds_per_cube": {"type": "integer", "minimum": 1},
            "end_to_end_timeout_seconds": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clock", "definitions"],
      "properties": {
        "clock": {"$ref": "#/$defs/nonEmptyString"},
        "definitions": {
          "type": "array",
          "minItems": 4,
          "items": {"$ref": "#/$defs/metric"}
        }
      }
    },
    "outcomes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_statuses", "sat_early_termination", "unsat", "unknown", "crash", "cancellation", "censoring"],
      "properties": {
        "allowed_statuses": {
          "type": "array",
          "minItems": 6,
          "uniqueItems": true,
          "items": {"enum": ["sat", "unsat", "unknown", "crash", "cancelled", "timeout"]}
        },
        "sat_early_termination": {"$ref": "#/$defs/nonEmptyString"},
        "unsat": {"$ref": "#/$defs/nonEmptyString"},
        "unknown": {"$ref": "#/$defs/nonEmptyString"},
        "crash": {"$ref": "#/$defs/nonEmptyString"},
        "cancellation": {"$ref": "#/$defs/nonEmptyString"},
        "censoring": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_records", "tables", "figures", "negative_controls"],
      "properties": {
        "raw_records": {
          "type": "object",
          "additionalProperties": false,
          "required": ["format", "one_record_per", "required_fields", "metrics"],
          "properties": {
            "format": {"enum": ["jsonl", "csv"]},
            "one_record_per": {"$ref": "#/$defs/nonEmptyString"},
            "required_fields": {"$ref": "#/$defs/nonEmptyStrings"},
            "metrics": {"$ref": "#/$defs/ids"}
          }
        },
        "tables": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/artifact"}
        },
        "figures": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/artifact"}
        },
        "negative_controls": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/negativeControl"}
        }
      }
    },
    "exclusions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/exclusion"}
    }
  },
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "id": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/nonEmptyString"}
    },
    "ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/id"}
    },
    "instance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "sha256", "parameters"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "path": {"$ref": "#/$defs/nonEmptyString"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["factor_bits", "index"],
          "properties": {
            "factor_bits": {"type": "integer", "minimum": 1},
            "index": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "benchmarkFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "generator", "instances", "splits"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "description": {"$ref": "#/$defs/nonEmptyString"},
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["command", "seed_base", "parameters", "source_revision"],
          "properties": {
            "command": {"$ref": "#/$defs/nonEmptyString"},
            "seed_base": {"type": "integer", "minimum": 0},
            "parameters": {"$ref": "#/$defs/nonEmptyString"},
            "source_revision": {"$ref": "#/$defs/sha256"}
          }
        },
        "instances": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/instance"}
        },
        "splits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["training", "validation", "held_out"],
          "properties": {
            "training": {"$ref": "#/$defs/ids"},
            "validation": {"$ref": "#/$defs/ids"},
            "held_out": {"$ref": "#/$defs/ids"}
          }
        }
      }
    },
    "method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "description", "partition_command", "conquer_command", "configuration", "artifact_status"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "role": {"enum": ["project", "direct_solve_reference", "cheap_branching_control", "partitioning_baseline"]},
        "description": {"$ref": "#/$defs/nonEmptyString"},
        "partition_command": {"$ref": "#/$defs/nonEmptyString"},
        "conquer_command": {"$ref": "#/$defs/nonEmptyString"},
        "configuration": {"$ref": "#/$defs/nonEmptyString"},
        "artifact_status": {"enum": ["reproducible_from_source", "pinned_binary", "documented_unavailable"]}
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "left", "right", "question", "controlled_factors"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "left": {"$ref": "#/$defs/id"},
        "right": {"$ref": "#/$defs/id"},
        "question": {"$ref": "#/$defs/nonEmptyString"},
        "controlled_factors": {"$ref": "#/$defs/nonEmptyStrings"}
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "source", "source_revision", "build", "executable", "executable_digest_policy"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "version": {"$ref": "#/$defs/nonEmptyString"},
        "source": {"$ref": "#/$defs/nonEmptyString"},
        "source_revision": {"$ref": "#/$defs/nonEmptyString"},
        "build": {"$ref": "#/$defs/nonEmptyString"},
        "executable": {"$ref": "#/$defs/nonEmptyString"},
        "executable_digest_policy": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "unit", "definition", "aggregation", "censoring"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "unit": {"$ref": "#/$defs/nonEmptyString"},
        "definition": {"$ref": "#/$defs/nonEmptyString"},
        "aggregation": {"$ref": "#/$defs/nonEmptyString"},
        "censoring": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "metrics"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "description": {"$ref": "#/$defs/nonEmptyString"},
        "metrics": {"$ref": "#/$defs/ids"}
      }
    },
    "negativeControl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "expected_result"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "description": {"$ref": "#/$defs/nonEmptyString"},
        "expected_result": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "exclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "reason", "consequence"],
      "properties": {
        "artifact": {"$ref": "#/$defs/nonEmptyString"},
        "reason": {"$ref": "#/$defs/nonEmptyString"},
        "consequence": {"$ref": "#/$defs/nonEmptyString"}
      }
    }
  }
}
